<Window x:Class="StockPlatform.Analyzer.GoldenCrossDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="判断依据" Height="950" Width="1400" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- 左：5个面板上下堆叠，对应金叉法7条规则实际用到的指标——主图(K线+MA5+MA10+压力线，
             条件1/2/7)、MACD(条件3)、KDJ(条件4)、RSI(条件5)、成交量(条件6)。 -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1.5*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="K线 / MA5 / MA10" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="MainInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="K线" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Blue" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MA5" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MA10" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="MainPlot" Model="{Binding MainPlotModel}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MACD" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="MacdInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="14" Height="3" Fill="Red" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MACD柱(正)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Green" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MACD柱(负)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Blue" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="DIF（快线）" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="DEA（慢线）" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="MacdPlot" Model="{Binding MacdPlotModel}" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="KDJ" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="KdjInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="14" Height="3" Fill="Blue" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="K" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="D" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="KdjPlot" Model="{Binding KdjPlotModel}" />
            </Grid>

            <Grid Grid.Row="3" Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="RSI" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="RsiInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="14" Height="3" Fill="Purple" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="RSI" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="RsiPlot" Model="{Binding RsiPlotModel}" />
            </Grid>

            <Grid Grid.Row="4" Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="成交量" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="VolumeInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="14" Height="3" Fill="Red" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="成交量(涨)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Green" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="成交量(跌)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="5日均量" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="VolumePlot" Model="{Binding VolumePlotModel}" />
            </Grid>
        </Grid>

        <!-- 右：标题 + 判断依据文字。 -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding Criteria}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                <Run Text="{Binding Icon}" FontWeight="Bold" />
                                <Run Text="{Binding Name}" FontWeight="Bold" />
                                <LineBreak />
                                <Run Text="{Binding Basis}" Foreground="Gray" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
