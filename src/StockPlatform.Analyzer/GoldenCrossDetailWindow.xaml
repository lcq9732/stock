<Window x:Class="StockPlatform.Analyzer.GoldenCrossDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="判断依据" Height="950" Width="1400" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- 左：5个面板上下堆叠，对应金叉法7条规则实际用到的指标——主图(K线+MA5+MA10+压力线，
             条件1/2/7)、MACD(条件3)、KDJ(条件4)、RSI(条件5)、成交量(条件6)。 -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1.5*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <oxy:PlotView x:Name="MainPlot" Model="{Binding MainPlotModel}" />
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,4,0,0"
                        Padding="6,3" Background="#DDFFFFFF" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" IsHitTestVisible="False">
                    <TextBlock x:Name="MainInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" />
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <oxy:PlotView x:Name="MacdPlot" Model="{Binding MacdPlotModel}" />
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,4,0,0"
                        Padding="6,3" Background="#DDFFFFFF" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" IsHitTestVisible="False">
                    <TextBlock x:Name="MacdInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" />
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,6,0,0">
                <oxy:PlotView x:Name="KdjPlot" Model="{Binding KdjPlotModel}" />
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,4,0,0"
                        Padding="6,3" Background="#DDFFFFFF" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" IsHitTestVisible="False">
                    <TextBlock x:Name="KdjInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" />
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="0,6,0,0">
                <oxy:PlotView x:Name="RsiPlot" Model="{Binding RsiPlotModel}" />
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,4,0,0"
                        Padding="6,3" Background="#DDFFFFFF" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" IsHitTestVisible="False">
                    <TextBlock x:Name="RsiInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" />
                </Border>
            </Grid>

            <Grid Grid.Row="4" Margin="0,6,0,0">
                <oxy:PlotView x:Name="VolumePlot" Model="{Binding VolumePlotModel}" />
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,4,0,0"
                        Padding="6,3" Background="#DDFFFFFF" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" IsHitTestVisible="False">
                    <TextBlock x:Name="VolumeInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" />
                </Border>
            </Grid>
        </Grid>

        <!-- 右：标题 + 判断依据文字。 -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding Criteria}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                <Run Text="{Binding Icon}" FontWeight="Bold" />
                                <Run Text="{Binding Name}" FontWeight="Bold" />
                                <LineBreak />
                                <Run Text="{Binding Basis}" Foreground="Gray" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
