<Window x:Class="StockPlatform.Analyzer.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="判断依据" Height="950" Width="1400" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- 左：两张图上下堆叠，把原来被上方文字占掉的高度让出来给图表。 -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <!-- 悬浮信息改成图表自己的一行表头（不再叠在图表上面）——之前叠在左上角会挡住那个
                 区域的K线/均线（价格靠图表上方时最明显），改成单独一行之后跟图表内容不会重叠，
                 也更接近典型股票APP"上面一行数字、下面走势图"的样子。见 DetailWindow.xaml.cs
                 OnPlotMouseMove。 -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- 表头一行：左边是鼠标所在日期的数值，右边是这张图的图例（颜色跟ChartBuilder.Build
                     里画的线手动对应）——日期只在最上面这个主图表头出现一次，下面MACD副图不重复。 -->
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="K线 / BOLL" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="MainInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="K线" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="LightGray" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="BOLL上轨" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="BOLL中轨" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="LightGray" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="BOLL下轨" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="MainPlot" Model="{Binding MainPlotModel}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MACD" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="MacdInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="14" Height="3" Fill="Red" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MACD柱(正)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Green" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MACD柱(负)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Blue" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="DIF（快线）" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="DEA（慢线）" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="MacdPlot" Model="{Binding MacdPlotModel}" />
            </Grid>
        </Grid>

        <!-- 右：标题 + 判断依据文字——原来在图表上方占一整行宽度，现在挪到侧边，让图表能用满
             整个窗口高度。 -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding Criteria}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                <Run Text="{Binding Icon}" FontWeight="Bold" />
                                <Run Text="{Binding Name}" FontWeight="Bold" />
                                <LineBreak />
                                <Run Text="{Binding Basis}" Foreground="Gray" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
