<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>StockPlatform.Analyzer</AssemblyName>
    <RootNamespace>StockPlatform.Analyzer</RootNamespace>
    <LangVersion>latest</LangVersion>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <DebugType>none</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OxyPlot.Wpf" Version="2.1.2" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\IndustryMap.tsv" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\StockPlatform.Logic\StockPlatform.Logic.csproj" />
    <ProjectReference Include="..\StockPlatform.Data\StockPlatform.Data.csproj" />
  </ItemGroup>

</Project>
