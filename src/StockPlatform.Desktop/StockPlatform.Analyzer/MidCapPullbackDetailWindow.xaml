<Window x:Class="StockPlatform.Analyzer.MidCapPullbackDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="判断依据" Height="950" Width="1400" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- 左：3个面板——日线主图(K线+MA15+涨停标记，规则5/8/9/10)、周线MACD(规则7)、
             月线MACD(规则6)。三个面板各自独立缩放/拖动（周期不同，没法共用同一根横轴）。 -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1.5*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="K线 / MA15" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="MainInfoText" Text="将鼠标移到图表上查看该日详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="K线" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MA15" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="▲" Foreground="Red" FontSize="11" Margin="0,0,2,0" VerticalAlignment="Center" />
                            <TextBlock Text="涨停" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="MainPlot" Model="{Binding MainPlotModel}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="周线MACD" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="WeekMacdInfoText" Text="将鼠标移到图表上查看该周详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="14" Height="3" Fill="Red" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MACD柱(正)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Green" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MACD柱(负)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Blue" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="DIF（快线）" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="DEA（慢线）" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="WeekMacdPlot" Model="{Binding WeekMacdPlotModel}" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="6,3" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="月线MACD" FontWeight="Bold" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="MonthMacdInfoText" Text="将鼠标移到图表上查看该月详细数据" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="14" Height="3" Fill="Red" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MACD柱(正)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Green" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="MACD柱(负)" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Blue" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="DIF（快线）" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Rectangle Width="14" Height="3" Fill="Orange" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="DEA（慢线）" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <oxy:PlotView Grid.Row="1" x:Name="MonthMacdPlot" Model="{Binding MonthMacdPlotModel}" />
            </Grid>
        </Grid>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding Criteria}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                <Run Text="{Binding Icon}" FontWeight="Bold" />
                                <Run Text="{Binding Name}" FontWeight="Bold" />
                                <LineBreak />
                                <Run Text="{Binding Basis}" Foreground="Gray" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
